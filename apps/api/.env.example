# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/replimap

# Security
JWT_SECRET=change-me-in-production
LICENSE_SIGNING_KEY=change-me-in-production

# Admin API key (required for admin endpoints like /create and /revoke)
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your-secure-admin-key-here

# Environment (development, production)
# When set to 'production', weak secrets will cause startup failure
ENVIRONMENT=development

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# Clerk (REQUIRED for authenticated endpoints, e.g. provision-community)
# CLERK_ISSUER is the instance Frontend API origin — the `iss` claim on Clerk
# session tokens and the JWKS host (https://<issuer>/.well-known/jwks.json).
# CLERK_SECRET_KEY resolves a user's email via the Clerk Backend API when the
# session token has no email claim. Without both, provision-community fails
# closed (503) rather than allowing unauthenticated access.
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_...

# Internal API header (Cloudflare WAF coordination — NOT read by the Worker)
# The web app sends `X-Internal-Auth: <INTERNAL_API_SECRET>` on its server-side
# provision-community call, and a Cloudflare WAF "Skip" rule matches that header
# to bypass Bot Fight Mode (which otherwise 403s Vercel's cloud-ASN requests
# before they reach the Worker). The Worker intentionally does NOT validate this
# header: the edge rule runs before the Worker, and the Clerk token is the real
# auth. Nothing to set here — the value lives in Vercel (as INTERNAL_API_SECRET)
# and in the Cloudflare WAF rule, and those two must match exactly.

# CORS (JSON array of origins)
CORS_ORIGINS=["http://localhost:3000"]

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Feature flags
ENABLE_USAGE_TRACKING=true
ENABLE_ACTIVATION_LIMITS=true
